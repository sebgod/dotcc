@page "/"
@using System.IO
@using System.Text
@using DotCC
@inject IJSRuntime JS

<PageTitle>dotcc — C to .NET/wasm, in your browser</PageTitle>

<header>
    <h1>dotcc <span class="tag">web sandbox</span></h1>
    <p class="blurb">
        A clang-shaped <strong>C&nbsp;→&nbsp;.NET/C#</strong> compiler with a
        WebAssembly backend — compiled to wasm and running <em>entirely in this
        tab</em>. Your code is transpiled by the real compiler, assembled to wasm,
        and executed here. Nothing leaves your browser.
    </p>
</header>

<div class="sandbox">
    <section class="editor">
        <div class="pane-head">
            <span>source.c</span>
            <label class="examples">
                example:
                <select @onchange="OnExampleChanged">
                    @foreach (var ex in Examples)
                    {
                        <option value="@ex.Name" selected="@(ex.Name == _example)">@ex.Name</option>
                    }
                </select>
            </label>
        </div>
        <div id="@EditorId" class="cm-host"></div>
        <div class="controls">
            <button class="run" @onclick="RunAsync" disabled="@_busy">
                @(_busy ? "Running…" : "▶ Run")
            </button>
            <button class="share" @onclick="ShareAsync" disabled="@_busy" title="Copy a self-contained link to this program">
                🔗 Share
            </button>
            <span class="hint">@_hint</span>
        </div>
        <div class="flags">
            <label class="std">-std=
                <select @bind="_std">
                    <option value="c90">c90</option>
                    <option value="c99">c99</option>
                    <option value="c11">c11</option>
                    <option value="c17">c17</option>
                    <option value="c23">c23</option>
                </select>
            </label>
            <label><input type="checkbox" @bind="_wConversion" /> -Wconversion</label>
            <label><input type="checkbox" @bind="_wFallthrough" /> -Wimplicit-fallthrough</label>
            <label><input type="checkbox" @bind="_pedantic" /> -pedantic</label>
        </div>
    </section>

    <section class="output">
        <div class="tabs">
            @foreach (var t in _tabs)
            {
                <button class="@(t == _tab ? "tab active" : "tab")" @onclick="() => Select(t)">@t</button>
            }
        </div>
        <div class="pane-body">
            @if (_tab == "Output")
            {
                @if (_ran)
                {
                    <pre class="stdout">@_stdout</pre>
                    @if (!string.IsNullOrEmpty(_stderr))
                    {
                        <div class="stream-label">stderr</div>
                        <pre class="stderr">@_stderr</pre>
                    }
                    <div class="exit @(_exitCode == 0 ? "ok" : "nonzero")">exit code: @_exitCode</div>
                }
                else
                {
                    <div class="empty">Press Run to compile and execute.</div>
                }
            }
            else if (_tab == "wat")
            {
                <pre class="code">@(_wat ?? "")</pre>
            }
            else if (_tab == "C#")
            {
                <pre class="code">@(_csharp ?? "")</pre>
            }
            else if (_tab == "-E")
            {
                <pre class="code">@(_preprocessed ?? "")</pre>
            }
        </div>
        @if (!string.IsNullOrEmpty(_diagnostics))
        {
            <div class="diagnostics @(_hasError ? "err" : "warn")">
                <pre>@_diagnostics</pre>
            </div>
        }
    </section>
</div>

@code {
    // The tab set: run output, then the three "look inside the compiler" views —
    // the wat the backend emits, the C# projection, and the -E token stream.
    private readonly string[] _tabs = { "Output", "wat", "C#", "-E" };
    private string _tab = "Output";

    private string _source = Examples[0].Source;
    private string _example = Examples[0].Name;
    private string? _wat;
    private string? _csharp;
    private string? _preprocessed;
    private string _stdout = "";
    private string _stderr = "";
    private int _exitCode;
    private string _diagnostics = "";
    private bool _hasError;
    private bool _ran;
    private bool _busy;
    private string _hint = "first run warms the compiler (~a few seconds)";

    // Compiler-option flags (read at Run time; passed to EmitWat/EmitCSharp/Preprocess).
    private string _std = "c17";
    private bool _wConversion;
    private bool _wFallthrough;
    private bool _pedantic;

    private void Select(string t) => _tab = t;

    // dotcc reads inputs off the (Emscripten in-memory) filesystem, so we stage the
    // editor buffer there — WEB0 confirmed the include-scan works over MEMFS.
    private const string WorkDir = "/work";
    private const string SourcePath = WorkDir + "/source.c";

    // The CodeMirror instance lives in JS (window.dotccEditor); `_source` is the
    // authoritative C# copy, pulled from the editor right before each compile/share.
    private const string EditorId = "editor";

    /// <summary>On first render, adopt any program packed into a "#src=…" share
    /// link so playground links round-trip, then mount the CodeMirror editor with
    /// the resolved source. JS interop is only legal once the component has
    /// rendered (this app is client-side WASM, no prerender).</summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) { return; }
        var shared = await JS.InvokeAsync<string?>("dotccSandbox.readShareSource");
        if (!string.IsNullOrEmpty(shared))
        {
            _source = shared;
            _example = "(shared link)";
        }
        await JS.InvokeVoidAsync("dotccEditor.create", EditorId, _source);
        if (!string.IsNullOrEmpty(shared)) { StateHasChanged(); }
    }

    /// <summary>Pull the live editor text into <see cref="_source"/> before a
    /// compile or share (the buffer of record is CodeMirror's, not the C# field).</summary>
    private async Task SyncFromEditor() =>
        _source = await JS.InvokeAsync<string>("dotccEditor.getValue", EditorId);

    private async Task OnExampleChanged(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        var picked = Array.Find(Examples, x => x.Name == name);
        if (picked is not null)
        {
            _source = picked.Source;
            _example = picked.Name;
            _ran = false;
            _diagnostics = "";
            _hasError = false;
            await JS.InvokeVoidAsync("dotccEditor.setValue", EditorId, picked.Source);
        }
    }

    private async Task ShareAsync()
    {
        await SyncFromEditor();
        var url = await JS.InvokeAsync<string>("dotccSandbox.makeShareLink", _source);
        _hint = url.Length > 60 ? "link copied to clipboard ✓" : url;
        StateHasChanged();
    }

    private async Task RunAsync()
    {
        _busy = true;
        _diagnostics = "";
        _hasError = false;
        StateHasChanged();

        await SyncFromEditor();

        // Compile on the .NET side: source -> wat (and C# / -E, for the view tabs).
        string? wat = null;
        try
        {
            Directory.CreateDirectory(WorkDir);
            File.WriteAllText(SourcePath, _source);

            var dialect = Dialect();
            var warnings = Warnings();

            wat = Emit(() => Compiler.EmitWat(new[] { SourcePath }, dialect: dialect, warnings: warnings), out var watWarnings);
            _wat = wat;
            // The C# projection and -E token stream are pure string passes too — cheap
            // to keep both view tabs live alongside a run. EmitCSharp is ALSO the source
            // of -Wconversion (a codegen-time gate the wat path doesn't run), so capture
            // its warnings too; both run the shared dialect gate, so dedupe against wat's
            // to avoid repeating -pedantic lines.
            string csWarnings = "";
            try { _csharp = Emit(() => Compiler.EmitCSharp(new[] { SourcePath }, dialect: dialect, warnings: warnings), out csWarnings); }
            catch { _csharp = "// (C# emit unavailable for this program)"; }
            _preprocessed = Preprocess(dialect);

            var diag = DedupeLines(watWarnings, csWarnings);
            if (!string.IsNullOrWhiteSpace(diag)) { SetDiag(diag, isError: false); }
        }
        catch (CompileException ex)
        {
            SetDiag(ex.Message, isError: true);
        }
        catch (Exception ex)
        {
            SetDiag($"internal: {ex.GetType().Name}: {ex.Message}", isError: true);
        }

        // Assemble + run in the browser via wabt + the fd_write shim.
        if (wat is not null)
        {
            try
            {
                var result = await JS.InvokeAsync<RunResult>("dotccSandbox.assembleAndRun", wat);
                if (result.Ok)
                {
                    _stdout = result.Stdout ?? "";
                    _stderr = result.Stderr ?? "";
                    _exitCode = result.ExitCode;
                    _ran = true;
                    _tab = "Output";
                }
                else
                {
                    SetDiag($"{result.Stage} error: {result.Error}", isError: true);
                }
            }
            catch (Exception ex)
            {
                SetDiag($"run host error: {ex.Message}", isError: true);
            }
        }

        _busy = false;
        StateHasChanged();
    }

    /// <summary>Run a compiler entry point while capturing the diagnostics it writes
    /// to <see cref="Console.Error"/> (warnings), restoring the previous writer after.</summary>
    private static string Emit(Func<string> emit, out string warnings)
    {
        var capture = new StringWriter();
        var previous = Console.Error;
        Console.SetError(capture);
        try { return emit(); }
        finally { Console.SetError(previous); warnings = capture.ToString(); }
    }

    /// <summary>Selected <c>-std=</c> dialect for the compile.</summary>
    private CDialect Dialect() => CDialect.Parse(_std);

    /// <summary>The warning bit set from the flag checkboxes, over the compiler default.</summary>
    private WarningFlags Warnings()
    {
        var w = WarningFlags.Default;
        if (_wConversion) { w |= WarningFlags.Conversion; }
        if (_wFallthrough) { w |= WarningFlags.ImplicitFallthrough; }
        if (_pedantic) { w |= WarningFlags.Pedantic; }
        return w;
    }

    /// <summary>Merge diagnostic blocks into distinct, order-preserving lines — the
    /// wat and C# passes both run the shared dialect gate, so a -pedantic line would
    /// otherwise appear twice.</summary>
    private static string DedupeLines(params string[] blocks)
    {
        var seen = new List<string>();
        foreach (var b in blocks)
        {
            foreach (var raw in b.Split('\n'))
            {
                var line = raw.TrimEnd('\r');
                if (line.Length > 0 && !seen.Contains(line)) { seen.Add(line); }
            }
        }
        return string.Join("\n", seen);
    }

    /// <summary>Render the -E preprocessor token stream for the current source
    /// (best effort — a lex failure surfaces as a comment rather than blocking a run).</summary>
    private string Preprocess(CDialect dialect)
    {
        try
        {
            var sw = new StringWriter();
            Compiler.Preprocess(new[] { SourcePath }, sw, dialect: dialect);
            return sw.ToString();
        }
        catch (Exception ex)
        {
            return $"// (-E unavailable: {ex.Message})";
        }
    }

    private void SetDiag(string text, bool isError)
    {
        _diagnostics = text.Trim();
        _hasError = isError;
        if (isError) { _ran = false; }
    }

    /// <summary>Marshalled result of <c>dotccSandbox.assembleAndRun</c>.</summary>
    private sealed class RunResult
    {
        public bool Ok { get; set; }
        public int ExitCode { get; set; }
        public string? Stdout { get; set; }
        public string? Stderr { get; set; }
        public string? Stage { get; set; }
        public string? Error { get; set; }
    }

    /// <summary>A named starter program. Kept to the integer + <c>printf</c> surface
    /// the wat backend runs today (same feature set as the verified factorial demo);
    /// wider constructs get added as the wat backend grows.</summary>
    private sealed record Example(string Name, string Source);

    private static readonly Example[] Examples =
    {
        new("Factorial",
            """
            #include <stdio.h>

            int factorial(int n) {
                return n <= 1 ? 1 : n * factorial(n - 1);
            }

            int main(void) {
                for (int i = 1; i <= 6; i++)
                    printf("%d! = %d\n", i, factorial(i));
                return 0;
            }

            """),
        new("FizzBuzz",
            """
            #include <stdio.h>

            int main(void) {
                for (int i = 1; i <= 15; i++) {
                    if (i % 15 == 0)     printf("FizzBuzz\n");
                    else if (i % 3 == 0) printf("Fizz\n");
                    else if (i % 5 == 0) printf("Buzz\n");
                    else                 printf("%d\n", i);
                }
                return 0;
            }

            """),
        new("Fibonacci",
            """
            #include <stdio.h>

            int main(void) {
                int a = 0, b = 1;
                for (int i = 0; i < 10; i++) {
                    printf("%d ", a);
                    int next = a + b;
                    a = b;
                    b = next;
                }
                printf("\n");
                return 0;
            }

            """),
        new("GCD (Euclid)",
            """
            #include <stdio.h>

            int gcd(int a, int b) {
                while (b != 0) {
                    int t = b;
                    b = a % b;
                    a = t;
                }
                return a;
            }

            int main(void) {
                printf("gcd(48, 36) = %d\n", gcd(48, 36));
                printf("gcd(17, 5)  = %d\n", gcd(17, 5));
                return 0;
            }

            """),
        new("Primes",
            """
            #include <stdio.h>

            int main(void) {
                for (int n = 2; n < 30; n++) {
                    int is_prime = 1;
                    for (int d = 2; d * d <= n; d++)
                        if (n % d == 0) { is_prime = 0; break; }
                    if (is_prime) printf("%d ", n);
                }
                printf("\n");
                return 0;
            }

            """),
    };
}
