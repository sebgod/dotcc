@page "/"
@using System.IO
@using System.Text
@using DotCC
@inject IJSRuntime JS

<PageTitle>dotcc — C to .NET/wasm, in your browser</PageTitle>

<header>
    <h1>dotcc <span class="tag">web sandbox</span></h1>
    <p class="blurb">
        A clang-shaped <strong>C&nbsp;→&nbsp;.NET/C#</strong> compiler with a
        WebAssembly backend — compiled to wasm and running <em>entirely in this
        tab</em>. Your code is transpiled by the real compiler, assembled to wasm,
        and executed here. Nothing leaves your browser.
    </p>
</header>

<div class="sandbox">
    <section class="editor">
        <div class="pane-head">source.c</div>
        <textarea @bind="_source" @bind:event="oninput" spellcheck="false"></textarea>
        <div class="controls">
            <button class="run" @onclick="RunAsync" disabled="@_busy">
                @(_busy ? "Running…" : "▶ Run")
            </button>
            <span class="hint">first run warms the compiler (~a few seconds)</span>
        </div>
    </section>

    <section class="output">
        <div class="tabs">
            @foreach (var t in _tabs)
            {
                <button class="@(t == _tab ? "tab active" : "tab")" @onclick="() => Select(t)">@t</button>
            }
        </div>
        <div class="pane-body">
            @if (_tab == "Output")
            {
                @if (_ran)
                {
                    <pre class="stdout">@_stdout</pre>
                    @if (!string.IsNullOrEmpty(_stderr))
                    {
                        <div class="stream-label">stderr</div>
                        <pre class="stderr">@_stderr</pre>
                    }
                    <div class="exit @(_exitCode == 0 ? "ok" : "nonzero")">exit code: @_exitCode</div>
                }
                else
                {
                    <div class="empty">Press Run to compile and execute.</div>
                }
            }
            else if (_tab == "wat")
            {
                <pre class="code">@(_wat ?? "")</pre>
            }
            else if (_tab == "C#")
            {
                <pre class="code">@(_csharp ?? "")</pre>
            }
        </div>
        @if (!string.IsNullOrEmpty(_diagnostics))
        {
            <div class="diagnostics @(_hasError ? "err" : "warn")">
                <pre>@_diagnostics</pre>
            </div>
        }
    </section>
</div>

@code {
    private const string DefaultSource =
        "#include <stdio.h>\n\n" +
        "int factorial(int n) {\n" +
        "    return n <= 1 ? 1 : n * factorial(n - 1);\n" +
        "}\n\n" +
        "int main(void) {\n" +
        "    for (int i = 1; i <= 6; i++)\n" +
        "        printf(\"%d! = %d\\n\", i, factorial(i));\n" +
        "    return 0;\n" +
        "}\n";

    private readonly string[] _tabs = { "Output", "wat", "C#" };
    private string _tab = "Output";

    private string _source = DefaultSource;
    private string? _wat;
    private string? _csharp;
    private string _stdout = "";
    private string _stderr = "";
    private int _exitCode;
    private string _diagnostics = "";
    private bool _hasError;
    private bool _ran;
    private bool _busy;

    private void Select(string t) => _tab = t;

    // dotcc reads inputs off the (Emscripten in-memory) filesystem, so we stage the
    // editor buffer there — WEB0 confirmed the include-scan works over MEMFS.
    private const string WorkDir = "/work";
    private const string SourcePath = WorkDir + "/source.c";

    private async Task RunAsync()
    {
        _busy = true;
        _diagnostics = "";
        _hasError = false;
        StateHasChanged();

        // Compile on the .NET side: source -> wat (and C#, for the view tab).
        string? wat = null;
        try
        {
            Directory.CreateDirectory(WorkDir);
            File.WriteAllText(SourcePath, _source);

            wat = Emit(() => Compiler.EmitWat(new[] { SourcePath }), out var watWarnings);
            _wat = wat;
            // The C# projection is a pure string too — cheap to keep the tab live.
            try { _csharp = Emit(() => Compiler.EmitCSharp(new[] { SourcePath }), out _); }
            catch { _csharp = "// (C# emit unavailable for this program)"; }

            if (!string.IsNullOrWhiteSpace(watWarnings)) { SetDiag(watWarnings, isError: false); }
        }
        catch (CompileException ex)
        {
            SetDiag(ex.Message, isError: true);
        }
        catch (Exception ex)
        {
            SetDiag($"internal: {ex.GetType().Name}: {ex.Message}", isError: true);
        }

        // Assemble + run in the browser via wabt + the fd_write shim.
        if (wat is not null)
        {
            try
            {
                var result = await JS.InvokeAsync<RunResult>("dotccSandbox.assembleAndRun", wat);
                if (result.Ok)
                {
                    _stdout = result.Stdout ?? "";
                    _stderr = result.Stderr ?? "";
                    _exitCode = result.ExitCode;
                    _ran = true;
                    _tab = "Output";
                }
                else
                {
                    SetDiag($"{result.Stage} error: {result.Error}", isError: true);
                }
            }
            catch (Exception ex)
            {
                SetDiag($"run host error: {ex.Message}", isError: true);
            }
        }

        _busy = false;
        StateHasChanged();
    }

    /// <summary>Run a compiler entry point while capturing the diagnostics it writes
    /// to <see cref="Console.Error"/> (warnings), restoring the previous writer after.</summary>
    private static string Emit(Func<string> emit, out string warnings)
    {
        var capture = new StringWriter();
        var previous = Console.Error;
        Console.SetError(capture);
        try { return emit(); }
        finally { Console.SetError(previous); warnings = capture.ToString(); }
    }

    private void SetDiag(string text, bool isError)
    {
        _diagnostics = text.Trim();
        _hasError = isError;
        if (isError) { _ran = false; }
    }

    /// <summary>Marshalled result of <c>dotccSandbox.assembleAndRun</c>.</summary>
    private sealed class RunResult
    {
        public bool Ok { get; set; }
        public int ExitCode { get; set; }
        public string? Stdout { get; set; }
        public string? Stderr { get; set; }
        public string? Stage { get; set; }
        public string? Error { get; set; }
    }
}
